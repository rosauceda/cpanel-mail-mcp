# ─────────────────────────────────────────────────────────────
# cpanel-mail-mcp — email accounts
# Copy this file to `.env` and fill in values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# ─── Option A: multi-account JSON (recommended if you have >1 account) ───
# EMAIL_ACCOUNTS_JSON='[
#   {
#     "name": "work",
#     "user": "me@work.com",
#     "password": "app_password_here",
#     "smtp_host": "mail.work.com",
#     "smtp_port": 465,
#     "imap_host": "mail.work.com",
#     "imap_port": 993,
#     "sent_folder": "INBOX.Sent",
#     "drafts_folder": "INBOX.Drafts",
#     "save_to_sent": true,
#     "from_name": "Me at Work"
#   },
#   {
#     "name": "gmail",
#     "user": "me@gmail.com",
#     "password": "app_password_here",
#     "smtp_host": "smtp.gmail.com",
#     "smtp_port": 587,
#     "imap_host": "imap.gmail.com",
#     "imap_port": 993,
#     "sent_folder": "[Gmail]/Sent Mail",
#     "drafts_folder": "[Gmail]/Drafts"
#   }
# ]'

# ─── Option B: JSON file with the same array ───
# EMAIL_ACCOUNTS_FILE=/absolute/path/to/accounts.json

# ─── Option C: single-account legacy vars (backward compatible) ───
CPANEL_USER=you@example.com
CPANEL_PASS=your_mailbox_password
CPANEL_SMTP_HOST=mail.example.com
CPANEL_SMTP_PORT=465            # 465 = implicit SSL ; 587 = STARTTLS
CPANEL_IMAP_HOST=mail.example.com
CPANEL_IMAP_PORT=993
CPANEL_SENT_FOLDER=INBOX.Sent
CPANEL_DRAFTS_FOLDER=INBOX.Drafts
CPANEL_SAVE_TO_SENT=true
# CPANEL_FROM_NAME=Your Display Name
# CPANEL_ACCOUNT_NAME=default    # optional friendly handle

# ─── Optional: send gate ───
# When set, `email(action='send'|'send_invite')` requires
# params.confirm=<code>. Prevents accidental sends from an agent.
# EMAIL_SEND_CONFIRMATION_CODE=please-actually-send
